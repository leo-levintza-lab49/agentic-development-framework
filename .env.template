# Claude Code Configuration
CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-1

# Local Paths (update for your environment)
SRE_TOOLS=/path/to/your/sre-tools

# GitHub Authentication (replace with your tokens)
GITHUB_AUTH_TOKEN=ghp_your_github_auth_token_here
ORG_ADMIN_PAT=ghp_your_org_admin_token_here
REPO_CREATE_PAT=ghp_your_repo_create_token_here

# Organization Names
MONOREPO_ORG=omnibase-poc
MULTIREPO_ORG=polybase-poc

# Validation Configuration
ENABLE_VALIDATION=true
VALIDATION_LEVEL=detailed
MAX_PARALLEL_REPOS=10
ENABLE_RATE_LIMIT_DETECTION=true
AUTO_ROLLBACK=true
PROMPT_ON_EXISTS=true
