# Kubernetes Manifest Configuration
# Example configuration file for generating manifests

# Application Configuration
APP_NAME=my-application
VERSION=1.0.0
ENVIRONMENT=production

# Container Image
IMAGE=myregistry.azurecr.io/my-application:1.0.0
IMAGE_PULL_POLICY=IfNotPresent
IMAGE_PULL_SECRETS=imagePullSecrets:\n  - name: acr-secret

# Deployment Configuration
REPLICAS=3
UPDATE_STRATEGY_TYPE=RollingUpdate
MAX_UNAVAILABLE=1
MAX_SURGE=1

# Ports
CONTAINER_PORT=8080
PORT=80
TARGET_PORT=8080
PORT_NAME=http

# Resource Limits
CPU_REQUEST=100m
CPU_LIMIT=500m
MEMORY_REQUEST=256Mi
MEMORY_LIMIT=1Gi

# Health Checks
LIVENESS_PATH=/health
LIVENESS_INITIAL_DELAY=30
LIVENESS_PERIOD=10
LIVENESS_TIMEOUT=5
LIVENESS_FAILURE_THRESHOLD=3

READINESS_PATH=/ready
READINESS_INITIAL_DELAY=10
READINESS_PERIOD=5
READINESS_TIMEOUT=3
READINESS_FAILURE_THRESHOLD=3

# Environment Variables
LOG_LEVEL=info
ADDITIONAL_ENV_VARS=""

# Security Context
RUN_AS_USER=1000
FS_GROUP=1000

# Service Configuration
SERVICE_NAME=my-application-service
SERVICE_TYPE=ClusterIP
SESSION_AFFINITY=""
ANNOTATIONS=""
ADDITIONAL_PORTS=""

# Ingress Configuration
INGRESS_NAME=my-application-ingress
INGRESS_CLASS=alb
HOST=app.example.com
PATHS="- path: /\n  pathType: Prefix\n  backend:\n    service:\n      name: my-application-service\n      port:\n        number: 80"
TLS_SECRET_NAME=app-tls-cert
ALB_SCHEME=internet-facing
ALB_TARGET_TYPE=ip
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxx
HEALTH_CHECK_PATH=/health
ADDITIONAL_ANNOTATIONS=""

# HPA Configuration
MIN_REPLICAS=2
MAX_REPLICAS=10
CPU_TARGET_UTILIZATION=70
MEMORY_TARGET_UTILIZATION=80
SCALE_DOWN_STABILIZATION=300
SCALE_DOWN_PERCENT=50
SCALE_DOWN_PODS=1
SCALE_DOWN_PERIOD=60
SCALE_UP_STABILIZATION=0
SCALE_UP_PERCENT=100
SCALE_UP_PODS=2
SCALE_UP_PERIOD=60
CUSTOM_METRICS=""

# ConfigMap
CONFIG_NAME=my-application-config
DATA="app.properties: |\n  database.host=db.example.com\n  cache.ttl=3600"

# Secret
SECRET_NAME=my-application-secrets
# DATA should be base64 encoded for secrets

# StatefulSet
STORAGE_CLASS=gp3
STORAGE_SIZE=10Gi
ACCESS_MODE=ReadWriteOnce
VOLUME_NAME=data
MOUNT_PATH=/data
POD_MANAGEMENT_POLICY=OrderedReady
ROLLING_UPDATE_CONFIG=""

# PVC
PVC_NAME=my-application-pvc
VOLUME_MODE=""
SELECTOR=""

# Job Configuration
JOB_NAME=my-application-job
BACKOFF_LIMIT=3
COMPLETIONS=1
PARALLELISM=1
TTL_SECONDS=86400
ACTIVE_DEADLINE_SECONDS=3600
RESTART_POLICY=Never
CONTAINER_NAME=job-container
COMMAND="[\"/bin/sh\"]"
ARGS="[\"-c\", \"echo Hello World\"]"
ENV_VARS=""

# CronJob Configuration
CRONJOB_NAME=my-application-cronjob
CRON_SCHEDULE="0 2 * * *"
TIMEZONE=UTC
SUCCESSFUL_JOBS_HISTORY_LIMIT=3
FAILED_JOBS_HISTORY_LIMIT=1
CONCURRENCY_POLICY=Forbid
STARTING_DEADLINE_SECONDS=300

# DaemonSet Configuration
DAEMONSET_NAME=my-application-daemonset
NODE_SELECTOR=""
TOLERATIONS=""
HOST_NETWORK=false
HOST_PID=false
HOST_IPC=false
PRIVILEGED=false
CAPABILITIES_ADD=""
TERMINATION_GRACE_PERIOD=30

# Namespace Configuration
NAMESPACE_NAME=my-namespace
TEAM=platform
CPU_REQUESTS_QUOTA=10
MEMORY_REQUESTS_QUOTA=20Gi
CPU_LIMITS_QUOTA=20
MEMORY_LIMITS_QUOTA=40Gi
PVC_QUOTA=10
PODS_QUOTA=50
SERVICES_QUOTA=10
LOAD_BALANCERS_QUOTA=2
MAX_CPU_PER_POD=4
MAX_MEMORY_PER_POD=8Gi
MIN_CPU_PER_POD=10m
MIN_MEMORY_PER_POD=64Mi
DEFAULT_CPU_LIMIT=500m
DEFAULT_MEMORY_LIMIT=512Mi
DEFAULT_CPU_REQUEST=100m
DEFAULT_MEMORY_REQUEST=128Mi
MAX_PVC_SIZE=100Gi
MIN_PVC_SIZE=1Gi

# Volume Configuration
VOLUMES=""
VOLUME_MOUNTS=""
ADDITIONAL_VOLUME_MOUNTS=""

# Probe Configuration
LIVENESS_PROBE="httpGet:\n  path: /health\n  port: http"
READINESS_PROBE="httpGet:\n  path: /ready\n  port: http"

# Additional Labels
ADDITIONAL_LABELS=""
