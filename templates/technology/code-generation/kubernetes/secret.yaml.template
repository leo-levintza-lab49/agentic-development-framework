---
apiVersion: v1
kind: Secret
metadata:
  name: {{SECRET_NAME}}
  labels:
    app: {{APP_NAME}}
type: Opaque
data:
  {{DATA}}
  # Example data structure (base64 encoded):
  # database-password: {{BASE64_DB_PASSWORD}}
  # api-key: {{BASE64_API_KEY}}
  # tls.crt: {{BASE64_TLS_CERT}}
  # tls.key: {{BASE64_TLS_KEY}}

# Note: To base64 encode values, use:
# echo -n 'your-secret-value' | base64
#
# For file contents:
# cat certificate.crt | base64

# Alternative: Use stringData for plain text (auto-encoded)
# stringData:
#   database-password: "{{DB_PASSWORD}}"
#   api-key: "{{API_KEY}}"
