---
apiVersion: v1
kind: Service
metadata:
  name: {{SERVICE_NAME}}
  labels:
    app: {{APP_NAME}}
  annotations:
    {{ANNOTATIONS}}
spec:
  type: {{SERVICE_TYPE}}
  ports:
  - port: {{PORT}}
    targetPort: {{TARGET_PORT}}
    protocol: TCP
    name: http
  {{ADDITIONAL_PORTS}}
  selector:
    app: {{APP_NAME}}
  {{SESSION_AFFINITY}}
