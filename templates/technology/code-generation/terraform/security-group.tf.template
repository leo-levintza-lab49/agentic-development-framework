# Security Group Template
# Description: Creates a security group with customizable ingress and egress rules
# Placeholders: {{SG_NAME}}, {{PORTS}}, {{VPC_ID}}, {{DESCRIPTION}}

locals {
  sg_name = "{{SG_NAME}}"

  tags = {
    Environment = "{{ENVIRONMENT}}"
    Project     = "{{PROJECT}}"
    ManagedBy   = "terraform"
  }
}

# Security Group
resource "aws_security_group" "main" {
  name_prefix = "${local.sg_name}-sg"
  description = "{{DESCRIPTION}}" # e.g., "Security group for application servers"
  vpc_id      = "{{VPC_ID}}"

  tags = merge(
    local.tags,
    {
      Name = "${local.sg_name}-sg"
    }
  )

  lifecycle {
    create_before_destroy = true
  }
}

# Ingress Rules - HTTP
resource "aws_security_group_rule" "ingress_http" {
  type              = "ingress"
  description       = "Allow HTTP traffic"
  from_port         = 80
  to_port           = 80
  protocol          = "tcp"
  cidr_blocks       = ["{{HTTP_CIDR_BLOCKS}}"] # e.g., ["0.0.0.0/0"] or specific IPs
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - HTTPS
resource "aws_security_group_rule" "ingress_https" {
  type              = "ingress"
  description       = "Allow HTTPS traffic"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = ["{{HTTPS_CIDR_BLOCKS}}"] # e.g., ["0.0.0.0/0"] or specific IPs
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - Application Port
resource "aws_security_group_rule" "ingress_app" {
  type              = "ingress"
  description       = "Allow application traffic on custom port"
  from_port         = {{APP_PORT}} # e.g., 8080
  to_port           = {{APP_PORT}}
  protocol          = "tcp"
  cidr_blocks       = ["{{APP_CIDR_BLOCKS}}"] # e.g., ["10.0.0.0/16"]
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - SSH (use Systems Manager Session Manager instead in production)
resource "aws_security_group_rule" "ingress_ssh" {
  type              = "ingress"
  description       = "Allow SSH access"
  from_port         = 22
  to_port           = 22
  protocol          = "tcp"
  cidr_blocks       = ["{{SSH_CIDR_BLOCKS}}"] # e.g., ["10.0.0.0/8"] - restrict to bastion/VPN
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - PostgreSQL
resource "aws_security_group_rule" "ingress_postgres" {
  type              = "ingress"
  description       = "Allow PostgreSQL traffic"
  from_port         = 5432
  to_port           = 5432
  protocol          = "tcp"
  cidr_blocks       = ["{{POSTGRES_CIDR_BLOCKS}}"] # e.g., ["10.0.0.0/16"]
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - MySQL/Aurora
resource "aws_security_group_rule" "ingress_mysql" {
  type              = "ingress"
  description       = "Allow MySQL/Aurora traffic"
  from_port         = 3306
  to_port           = 3306
  protocol          = "tcp"
  cidr_blocks       = ["{{MYSQL_CIDR_BLOCKS}}"] # e.g., ["10.0.0.0/16"]
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - Redis
resource "aws_security_group_rule" "ingress_redis" {
  type              = "ingress"
  description       = "Allow Redis traffic"
  from_port         = 6379
  to_port           = 6379
  protocol          = "tcp"
  cidr_blocks       = ["{{REDIS_CIDR_BLOCKS}}"] # e.g., ["10.0.0.0/16"]
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - From Another Security Group
resource "aws_security_group_rule" "ingress_from_sg" {
  type                     = "ingress"
  description              = "Allow traffic from another security group"
  from_port                = {{FROM_SG_PORT}} # e.g., 8080
  to_port                  = {{FROM_SG_PORT}}
  protocol                 = "tcp"
  source_security_group_id = "{{SOURCE_SECURITY_GROUP_ID}}" # e.g., security group ID of ALB
  security_group_id        = aws_security_group.main.id
}

# Ingress Rules - Custom Port Range
resource "aws_security_group_rule" "ingress_port_range" {
  type              = "ingress"
  description       = "Allow traffic on custom port range"
  from_port         = {{PORT_RANGE_START}} # e.g., 9000
  to_port           = {{PORT_RANGE_END}}   # e.g., 9100
  protocol          = "tcp"
  cidr_blocks       = ["{{PORT_RANGE_CIDR_BLOCKS}}"]
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - All Traffic from VPC (use cautiously)
resource "aws_security_group_rule" "ingress_vpc_all" {
  type              = "ingress"
  description       = "Allow all traffic from VPC CIDR"
  from_port         = 0
  to_port           = 65535
  protocol          = "tcp"
  cidr_blocks       = ["{{VPC_CIDR_BLOCK}}"] # e.g., ["10.0.0.0/16"]
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - ICMP (ping)
resource "aws_security_group_rule" "ingress_icmp" {
  type              = "ingress"
  description       = "Allow ICMP ping"
  from_port         = -1
  to_port           = -1
  protocol          = "icmp"
  cidr_blocks       = ["{{ICMP_CIDR_BLOCKS}}"] # e.g., ["10.0.0.0/16"]
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - NFS
resource "aws_security_group_rule" "ingress_nfs" {
  type              = "ingress"
  description       = "Allow NFS traffic"
  from_port         = 2049
  to_port           = 2049
  protocol          = "tcp"
  cidr_blocks       = ["{{NFS_CIDR_BLOCKS}}"]
  security_group_id = aws_security_group.main.id
}

# Ingress Rules - Kubernetes NodePort Range
resource "aws_security_group_rule" "ingress_k8s_nodeport" {
  type              = "ingress"
  description       = "Allow Kubernetes NodePort traffic"
  from_port         = 30000
  to_port           = 32767
  protocol          = "tcp"
  cidr_blocks       = ["{{K8S_CIDR_BLOCKS}}"]
  security_group_id = aws_security_group.main.id
}

# Egress Rules - All Traffic (default)
resource "aws_security_group_rule" "egress_all" {
  type              = "egress"
  description       = "Allow all outbound traffic"
  from_port         = 0
  to_port           = 0
  protocol          = "-1"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.main.id
}

# Egress Rules - Specific Protocol and Port
resource "aws_security_group_rule" "egress_https" {
  type              = "egress"
  description       = "Allow HTTPS outbound traffic"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.main.id
}

# Egress Rules - To Another Security Group
resource "aws_security_group_rule" "egress_to_sg" {
  type                     = "egress"
  description              = "Allow traffic to another security group"
  from_port                = {{TO_SG_PORT}} # e.g., 5432
  to_port                  = {{TO_SG_PORT}}
  protocol                 = "tcp"
  source_security_group_id = "{{DEST_SECURITY_GROUP_ID}}" # e.g., security group ID of RDS
  security_group_id        = aws_security_group.main.id
}

# Egress Rules - VPC Endpoints
resource "aws_security_group_rule" "egress_vpc_endpoints" {
  type              = "egress"
  description       = "Allow traffic to VPC endpoints"
  from_port         = 443
  to_port           = 443
  protocol          = "tcp"
  prefix_list_ids   = ["{{PREFIX_LIST_ID}}"] # e.g., S3 prefix list
  security_group_id = aws_security_group.main.id
}

# Self-Referencing Rule (for cluster communication)
resource "aws_security_group_rule" "self_reference" {
  type              = "ingress"
  description       = "Allow traffic within the security group"
  from_port         = 0
  to_port           = 65535
  protocol          = "tcp"
  self              = true
  security_group_id = aws_security_group.main.id
}

# Dynamic Ingress Rules (using for_each)
variable "custom_ingress_rules" {
  description = "Map of custom ingress rules"
  type = map(object({
    description = string
    from_port   = number
    to_port     = number
    protocol    = string
    cidr_blocks = list(string)
  }))
  default = {
    # Example:
    # "rule1" = {
    #   description = "Allow custom port"
    #   from_port   = 8080
    #   to_port     = 8080
    #   protocol    = "tcp"
    #   cidr_blocks = ["10.0.0.0/16"]
    # }
  }
}

resource "aws_security_group_rule" "custom_ingress" {
  for_each = var.custom_ingress_rules

  type              = "ingress"
  description       = each.value.description
  from_port         = each.value.from_port
  to_port           = each.value.to_port
  protocol          = each.value.protocol
  cidr_blocks       = each.value.cidr_blocks
  security_group_id = aws_security_group.main.id
}

# Dynamic Egress Rules (using for_each)
variable "custom_egress_rules" {
  description = "Map of custom egress rules"
  type = map(object({
    description = string
    from_port   = number
    to_port     = number
    protocol    = string
    cidr_blocks = list(string)
  }))
  default = {}
}

resource "aws_security_group_rule" "custom_egress" {
  for_each = var.custom_egress_rules

  type              = "egress"
  description       = each.value.description
  from_port         = each.value.from_port
  to_port           = each.value.to_port
  protocol          = each.value.protocol
  cidr_blocks       = each.value.cidr_blocks
  security_group_id = aws_security_group.main.id
}

# VPC Flow Logs for Security Group (requires VPC Flow Logs enabled)
# This helps monitor traffic to/from resources using this security group

# CloudWatch Log Group for Security Group Logs
resource "aws_cloudwatch_log_group" "sg_logs" {
  name              = "/aws/securitygroup/${local.sg_name}"
  retention_in_days = 30

  tags = local.tags
}

# Outputs
output "security_group_id" {
  description = "The ID of the security group"
  value       = aws_security_group.main.id
}

output "security_group_arn" {
  description = "The ARN of the security group"
  value       = aws_security_group.main.arn
}

output "security_group_name" {
  description = "The name of the security group"
  value       = aws_security_group.main.name
}

output "security_group_vpc_id" {
  description = "The VPC ID of the security group"
  value       = aws_security_group.main.vpc_id
}

output "security_group_owner_id" {
  description = "The owner ID of the security group"
  value       = aws_security_group.main.owner_id
}
