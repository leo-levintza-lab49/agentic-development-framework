# CodeBuild Role
data "aws_iam_policy_document" "codebuild_assume_role" {
  statement {
    effect = "Allow"

    principals {
      type        = "Service"
      identifiers = ["codebuild.amazonaws.com"]
    }

    actions = ["sts:AssumeRole"]
  }
}

resource "aws_iam_role" "codebuild" {
  name               = "${local.role_name}-codebuild"
  assume_role_policy = data.aws_iam_policy_document.codebuild_assume_role.json

  tags = local.tags
}

# Cross-Account Access Role
data "aws_iam_policy_document" "cross_account_assume_role" {
  statement {
    effect = "Allow"

    principals {
      type        = "AWS"
      identifiers = ["arn:aws:iam::{{TRUSTED_ACCOUNT_ID}}:root"]
    }

    actions = ["sts:AssumeRole"]

    condition {
      test     = "StringEquals"
      variable = "sts:ExternalId"
      values   = ["{{EXTERNAL_ID}}"]
    }
  }
}

resource "aws_iam_role" "cross_account" {
  name               = "${local.role_name}-cross-account"
  assume_role_policy = data.aws_iam_policy_document.cross_account_assume_role.json

  tags = local.tags
}

# SAML Federation Role
data "aws_iam_policy_document" "saml_assume_role" {
  statement {
    effect = "Allow"

    principals {
      type        = "Federated"
      identifiers = ["arn:aws:iam::{{ACCOUNT_ID}}:saml-provider/{{SAML_PROVIDER_NAME}}"]
    }

    actions = ["sts:AssumeRoleWithSAML"]

    condition {
      test     = "StringEquals"
      variable = "SAML:aud"
      values   = ["https://signin.aws.amazon.com/saml"]
    }
  }
}

resource "aws_iam_role" "saml" {
  name               = "${local.role_name}-saml"
  assume_role_policy = data.aws_iam_policy_document.saml_assume_role.json

  tags = local.tags
}

# Outputs
output "role_arn" {
  description = "ARN of the IAM role"
  value       = aws_iam_role.main.arn
}

output "role_name" {
  description = "Name of the IAM role"
  value       = aws_iam_role.main.name
}

output "role_id" {
  description = "Unique ID of the IAM role"
  value       = aws_iam_role.main.unique_id
}

output "policy_arn" {
  description = "ARN of the IAM policy"
  value       = aws_iam_policy.main.arn
}

output "instance_profile_arn" {
  description = "ARN of the instance profile"
  value       = aws_iam_instance_profile.main.arn
}

output "instance_profile_name" {
  description = "Name of the instance profile"
  value       = aws_iam_instance_profile.main.name
}
