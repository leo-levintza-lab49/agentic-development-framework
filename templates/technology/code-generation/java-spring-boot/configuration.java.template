/**
 * Aspect configuration for cross-cutting concerns.
 *
 * @author Generated
 * @version 1.0
 */
@Configuration
@org.springframework.context.annotation.EnableAspectJAutoProxy
class AspectConfiguration {

    /**
     * Logging aspect for method execution.
     */
    @Bean
    public org.aspectj.lang.annotation.Aspect loggingAspect() {
        return new LoggingAspect();
    }

    /**
     * Performance monitoring aspect.
     */
    @Bean
    public org.aspectj.lang.annotation.Aspect performanceAspect() {
        return new PerformanceAspect();
    }
}

/**
 * Logging aspect for automatic method logging.
 */
@org.aspectj.lang.annotation.Aspect
@org.springframework.stereotype.Component
class LoggingAspect {

    private static final org.slf4j.Logger log = org.slf4j.LoggerFactory.getLogger(LoggingAspect.class);

    @org.aspectj.lang.annotation.Around("execution(* {{PACKAGE_NAME}}.service..*(..))")
    public Object logServiceMethods(org.aspectj.lang.ProceedingJoinPoint joinPoint) throws Throwable {
        String methodName = joinPoint.getSignature().toShortString();
        log.debug("Entering method: {}", methodName);

        long startTime = System.currentTimeMillis();
        try {
            Object result = joinPoint.proceed();
            long duration = System.currentTimeMillis() - startTime;
            log.debug("Exiting method: {} ({}ms)", methodName, duration);
            return result;
        } catch (Exception e) {
            log.error("Exception in method: {} - {}", methodName, e.getMessage());
            throw e;
        }
    }
}

/**
 * Performance monitoring aspect.
 */
@org.aspectj.lang.annotation.Aspect
@org.springframework.stereotype.Component
class PerformanceAspect {

    private static final org.slf4j.Logger log = org.slf4j.LoggerFactory.getLogger(PerformanceAspect.class);
    private static final long SLOW_THRESHOLD_MS = 1000; // Log if method takes longer than 1 second

    @org.aspectj.lang.annotation.Around("execution(* {{PACKAGE_NAME}}..*(..))")
    public Object monitorPerformance(org.aspectj.lang.ProceedingJoinPoint joinPoint) throws Throwable {
        long startTime = System.currentTimeMillis();
        Object result = joinPoint.proceed();
        long duration = System.currentTimeMillis() - startTime;

        if (duration > SLOW_THRESHOLD_MS) {
            log.warn("Slow method detected: {} took {}ms",
                    joinPoint.getSignature().toShortString(), duration);
        }

        return result;
    }
}
