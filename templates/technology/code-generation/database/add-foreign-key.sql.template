--     ON UPDATE CASCADE;

-- ============================================
-- CREATE SUPPORTING INDEX
-- ============================================

-- Create index on foreign key column for better join performance
CREATE INDEX CONCURRENTLY IF NOT EXISTS idx_{{TABLE_NAME}}_{{COLUMN_NAME}}
ON {{TABLE_NAME}} ({{COLUMN_NAME}});

-- Composite index for multi-column foreign keys
-- CREATE INDEX CONCURRENTLY IF NOT EXISTS idx_{{TABLE_NAME}}_fk_columns
-- ON {{TABLE_NAME}} (column1, column2);

-- ============================================
-- ADD CONSTRAINT COMMENT
-- ============================================

COMMENT ON CONSTRAINT {{FK_NAME}} ON {{TABLE_NAME}} IS '{{DESCRIPTION}}';

-- ============================================
-- POST-CONSTRAINT VALIDATION
-- ============================================

-- Verify constraint was created
SELECT
    tc.constraint_name,
    tc.table_name,
    kcu.column_name,
    ccu.table_name AS foreign_table_name,
    ccu.column_name AS foreign_column_name,
    rc.update_rule,
    rc.delete_rule
FROM information_schema.table_constraints AS tc
JOIN information_schema.key_column_usage AS kcu
    ON tc.constraint_name = kcu.constraint_name
    AND tc.table_schema = kcu.table_schema
JOIN information_schema.constraint_column_usage AS ccu
    ON ccu.constraint_name = tc.constraint_name
    AND ccu.table_schema = tc.table_schema
JOIN information_schema.referential_constraints AS rc
    ON tc.constraint_name = rc.constraint_name
WHERE tc.constraint_type = 'FOREIGN KEY'
  AND tc.table_name = '{{TABLE_NAME}}'
  AND tc.constraint_name = '{{FK_NAME}}';

-- Check for any remaining constraint violations
SELECT COUNT(*) AS remaining_violations
FROM {{TABLE_NAME}} t
WHERE {{COLUMN_NAME}} IS NOT NULL
  AND NOT EXISTS (
      SELECT 1
      FROM {{REF_TABLE}} r
      WHERE r.{{REF_COLUMN}} = t.{{COLUMN_NAME}}
  );

