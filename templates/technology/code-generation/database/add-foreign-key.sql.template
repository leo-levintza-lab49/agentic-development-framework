-- Template: Add Foreign Key Constraint
-- Description: Create foreign key relationships with referential integrity
-- Variables: {{FK_NAME}}, {{TABLE_NAME}}, {{COLUMN_NAME}}, {{REF_TABLE}}, {{REF_COLUMN}}

-- Foreign Key: {{FK_NAME}}
-- Description: {{DESCRIPTION}}
-- Relationship: {{TABLE_NAME}}.{{COLUMN_NAME}} -> {{REF_TABLE}}.{{REF_COLUMN}}

-- ============================================
-- PRE-CONSTRAINT VALIDATION
-- ============================================

-- Check for orphaned records (records that would violate the FK)
SELECT COUNT(*) AS orphaned_records
FROM {{TABLE_NAME}} t
WHERE {{COLUMN_NAME}} IS NOT NULL
  AND NOT EXISTS (
      SELECT 1
      FROM {{REF_TABLE}} r
      WHERE r.{{REF_COLUMN}} = t.{{COLUMN_NAME}}
  );

-- View orphaned records for cleanup
SELECT t.*
FROM {{TABLE_NAME}} t
WHERE {{COLUMN_NAME}} IS NOT NULL
  AND NOT EXISTS (
      SELECT 1
      FROM {{REF_TABLE}} r
      WHERE r.{{REF_COLUMN}} = t.{{COLUMN_NAME}}
  )
LIMIT 10;

