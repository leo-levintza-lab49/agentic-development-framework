-- COMMON FOREIGN KEY PATTERNS
-- ============================================

-- Pattern 1: Self-referential foreign key (tree structure)
-- ALTER TABLE categories
-- ADD CONSTRAINT fk_categories_parent_id
--     FOREIGN KEY (parent_id)
--     REFERENCES categories (id)
--     ON DELETE CASCADE;

-- Pattern 2: Soft delete safe foreign key
-- ALTER TABLE {{TABLE_NAME}}
-- ADD CONSTRAINT {{FK_NAME}}
--     FOREIGN KEY ({{COLUMN_NAME}})
--     REFERENCES {{REF_TABLE}} ({{REF_COLUMN}})
--     ON DELETE RESTRICT;  -- Prevent hard deletes, use soft delete instead

-- Pattern 3: Audit table foreign key (never delete audits)
-- ALTER TABLE audit_log
-- ADD CONSTRAINT fk_audit_log_user_id
--     FOREIGN KEY (user_id)
--     REFERENCES users (id)
--     ON DELETE SET NULL;  -- Keep audit even if user is deleted

-- ============================================
-- ON DELETE/UPDATE RULES GUIDE
-- ============================================

-- CASCADE:       Automatically delete/update child records
-- RESTRICT:      Prevent delete/update if child records exist (error immediately)
-- NO ACTION:     Prevent delete/update if child records exist (check at end of transaction)
-- SET NULL:      Set foreign key to NULL when parent is deleted/updated
-- SET DEFAULT:   Set foreign key to default value when parent is deleted/updated

-- ============================================
-- NOTES
-- ============================================

-- Performance considerations:
--   - Always create an index on foreign key columns
--   - Use CONCURRENTLY for index creation on large tables
--   - CASCADE can cause unexpected deletions, use with caution
--   - RESTRICT is safer but requires manual cleanup

-- Best practices:
--   - Document the relationship and chosen delete rule
--   - Test cascade behavior in staging environment
--   - Monitor foreign key constraint violations in logs
--   - Consider soft deletes instead of hard deletes for critical data
