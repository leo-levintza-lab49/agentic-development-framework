-- ============================================
-- ADD FOREIGN KEY CONSTRAINT
-- ============================================

-- Standard foreign key with CASCADE delete
ALTER TABLE {{TABLE_NAME}}
ADD CONSTRAINT {{FK_NAME}}
    FOREIGN KEY ({{COLUMN_NAME}})
    REFERENCES {{REF_TABLE}} ({{REF_COLUMN}})
    ON DELETE CASCADE
    ON UPDATE CASCADE;

-- Alternative: RESTRICT (prevent delete if referenced)
-- ALTER TABLE {{TABLE_NAME}}
-- ADD CONSTRAINT {{FK_NAME}}
--     FOREIGN KEY ({{COLUMN_NAME}})
--     REFERENCES {{REF_TABLE}} ({{REF_COLUMN}})
--     ON DELETE RESTRICT
--     ON UPDATE RESTRICT;

-- Alternative: SET NULL (nullify reference on delete)
-- ALTER TABLE {{TABLE_NAME}}
-- ADD CONSTRAINT {{FK_NAME}}
--     FOREIGN KEY ({{COLUMN_NAME}})
--     REFERENCES {{REF_TABLE}} ({{REF_COLUMN}})
--     ON DELETE SET NULL
--     ON UPDATE CASCADE;

-- Alternative: SET DEFAULT (set to default value on delete)
-- ALTER TABLE {{TABLE_NAME}}
-- ADD CONSTRAINT {{FK_NAME}}
--     FOREIGN KEY ({{COLUMN_NAME}})
--     REFERENCES {{REF_TABLE}} ({{REF_COLUMN}})
--     ON DELETE SET DEFAULT
--     ON UPDATE CASCADE;

-- Alternative: NO ACTION (similar to RESTRICT)
-- ALTER TABLE {{TABLE_NAME}}
-- ADD CONSTRAINT {{FK_NAME}}
--     FOREIGN KEY ({{COLUMN_NAME}})
--     REFERENCES {{REF_TABLE}} ({{REF_COLUMN}})
--     ON DELETE NO ACTION
--     ON UPDATE NO ACTION;

-- Composite foreign key (multiple columns)
-- ALTER TABLE {{TABLE_NAME}}
-- ADD CONSTRAINT {{FK_NAME}}
--     FOREIGN KEY (column1, column2)
--     REFERENCES {{REF_TABLE}} (ref_column1, ref_column2)
