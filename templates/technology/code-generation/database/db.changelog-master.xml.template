<?xml version="1.0" encoding="UTF-8"?>
<!-- Template: Liquibase Master Changelog
     Description: Master changelog file that includes all database changesets
     Variables: {{PROJECT_NAME}}, {{DATABASE_NAME}}, {{ENVIRONMENT}} -->

<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:pro="http://www.liquibase.org/xml/ns/pro"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd
        http://www.liquibase.org/xml/ns/dbchangelog-ext
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
        http://www.liquibase.org/xml/ns/pro
        http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.20.xsd">

    <!-- ============================================
         PROJECT INFORMATION
         ============================================ -->
    <property name="project.name" value="{{PROJECT_NAME}}"/>
    <property name="database.name" value="{{DATABASE_NAME}}"/>

    <!-- ============================================
         DATABASE PROPERTIES
         ============================================ -->

    <!-- PostgreSQL-specific properties -->
    <property name="now" value="now()" dbms="postgresql"/>
    <property name="autoIncrement" value="true" dbms="postgresql"/>
    <property name="blob.type" value="bytea" dbms="postgresql"/>
    <property name="text.type" value="TEXT" dbms="postgresql"/>
    <property name="uuid.type" value="UUID" dbms="postgresql"/>
    <property name="json.type" value="JSONB" dbms="postgresql"/>

    <!-- MySQL-specific properties -->
    <property name="now" value="NOW()" dbms="mysql"/>
    <property name="autoIncrement" value="true" dbms="mysql"/>
    <property name="blob.type" value="LONGBLOB" dbms="mysql"/>
    <property name="text.type" value="TEXT" dbms="mysql"/>
    <property name="uuid.type" value="VARCHAR(36)" dbms="mysql"/>
    <property name="json.type" value="JSON" dbms="mysql"/>

    <!-- ============================================
         ENVIRONMENT-SPECIFIC CONTEXTS
         ============================================ -->

    <!-- Contexts allow conditional execution of changesets -->
    <!-- Example usage: <changeSet context="dev,test"> -->

    <!-- ============================================
         PRECONDITIONS
         ============================================ -->

    <preConditions>
        <dbms type="postgresql"/>
        <!-- <runningAs username="db_admin"/> -->
    </preConditions>

    <!-- ============================================
         INITIAL SETUP
         ============================================ -->

    <!-- Create schema migrations tracking table -->
    <changeSet id="00000-create-schema-migrations-table" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="schema_migrations"/>
            </not>
        </preConditions>

        <createTable tableName="schema_migrations">
            <column name="version" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="applied_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="applied_by" type="VARCHAR(255)"/>
            <column name="execution_time_ms" type="INTEGER"/>
            <column name="checksum" type="VARCHAR(64)"/>
        </createTable>

        <rollback>
            <dropTable tableName="schema_migrations"/>
        </rollback>
    </changeSet>

    <!-- Create common functions and triggers -->
    <changeSet id="00001-create-common-functions" author="system">
        <sql splitStatements="false">
            -- Function to automatically update updated_at timestamp
            CREATE OR REPLACE FUNCTION update_updated_at_column()
            RETURNS TRIGGER AS $$
            BEGIN
                NEW.updated_at = CURRENT_TIMESTAMP;
                RETURN NEW;
            END;
            $$ language 'plpgsql';

            -- Function for soft delete
            CREATE OR REPLACE FUNCTION soft_delete()
            RETURNS TRIGGER AS $$
            BEGIN
                NEW.deleted_at = CURRENT_TIMESTAMP;
                RETURN NEW;
            END;
            $$ language 'plpgsql';
        </sql>

        <rollback>
            DROP FUNCTION IF EXISTS update_updated_at_column() CASCADE;
            DROP FUNCTION IF EXISTS soft_delete() CASCADE;
        </rollback>
    </changeSet>

    <!-- ============================================
         FOUNDATION SCHEMA (Version 1.0.x)
         ============================================ -->

    <!-- Base tables and core functionality -->
    <include file="db/changelog/v1.0/01-create-users-table.xml" relativeToChangelogFile="false"/>
