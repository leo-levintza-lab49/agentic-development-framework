-- Generate multiple rows with a loop
DO $$
DECLARE
    i INTEGER;
BEGIN
    FOR i IN 1..10 LOOP
        INSERT INTO {{TABLE_NAME}} (name, code, order_number, created_at)
        VALUES (
            'Generated Item ' || i,
            'CODE_' || LPAD(i::TEXT, 4, '0'),
            i,
            NOW() - (i || ' days')::INTERVAL
        )
        ON CONFLICT DO NOTHING;
    END LOOP;
END $$;

